{
  "name": "thread-monorepo",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "dev": "turbo run dev --ui tui",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "fmt": "turbo run fmt",
    "fmt:check": "turbo run fmt:check",
    "db:generate": "pnpm --filter @thread/db db:generate",
    "db:migrate": "pnpm --filter @thread/db db:migrate"
  },
  "devDependencies": {
    "turbo": "^2.5.6",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0"
  }
}
